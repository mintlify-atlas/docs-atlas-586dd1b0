  "keyFeatures": [
    "Dynamic category-based product filtering",
    "Responsive navbar with mobile drawer menu",
    "Product card display with badges and pricing",
    "REST API integration for menu data",
    "Material Symbols icon integration",
    "Loading and error state handling"
  ],
  "publicApiSurface": [
    "getCategorias() - Fetch all product categories",
    "getComidas() - Fetch all food products",
    "getProductsByCategory(categoryId) - Fetch products by category",
    "<Navbar /> - Navigation component with categories",
    "<Categories /> - Category filter component",
    "<ProductCard /> - Product display component",
    "<LogoSplash /> - Splash screen component",
    "<Footer /> - Footer component",
    "<Menu /> - Main menu page component"
